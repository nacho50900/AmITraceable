# Credenciales de la app de Reddit (https://www.reddit.com/prefs/apps)
# Crear una app de tipo "web app"
REDDIT_CLIENT_ID=tu_client_id_aqui
REDDIT_CLIENT_SECRET=tu_client_secret_aqui
REDDIT_REDIRECT_URI=http://localhost:3000/auth/reddit/callback
REDDIT_USER_AGENT=tfg-identity-exposure-tool/0.1 by tu_usuario_reddit

# Clave para firmar la sesión (cookies firmadas, NO se persiste nada en BD)
SESSION_SECRET_KEY=cambia_esto_por_una_cadena_aleatoria_larga

# Credenciales de la app de Instagram (Business Login for Instagram).
# Meta for Developers -> tu app -> Instagram -> "API setup with Instagram Login"
# Requiere que el usuario tenga una cuenta Instagram Business o Creator, y
# (mientras la app esté en modo desarrollo) que esté añadido como Tester en
# App roles -> Roles. Opcional: si se deja vacío, el módulo de Reddit sigue
# funcionando igual, solo el de Instagram devuelve 503.
INSTAGRAM_APP_ID=tu_instagram_app_id_aqui
INSTAGRAM_APP_SECRET=tu_instagram_app_secret_aqui
# Opcional. Si se deja vacía, se deriva automáticamente del Host de cada
# petición (útil con túneles rápidos de Cloudflare, que cambian de URL en
# cada reinicio -- así no hay que tocar esta variable cada vez). Fíjala
# explícitamente solo si despliegas con un dominio propio y estable.
# En cualquier caso, la URL resultante debe seguir dada de alta a mano en
# Meta for Developers -> tu app -> Instagram -> API setup with Instagram
# Login -> OAuth redirect URIs (Meta no tiene API para eso).
INSTAGRAM_REDIRECT_URI=

# Frontend
FRONTEND_ORIGIN=http://localhost:5173

# Análisis con IA (opcional). Tier gratuito de Mistral AI (La Plateforme,
# https://console.mistral.ai) -- proveedor europeo (Francia), evitando
# transferencias internacionales de datos personales fuera de la UE.
# Si se deja vacío, el botón "Analizar con IA" del dashboard simplemente
# indica que no está disponible; el resto de la app sigue funcionando igual.
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
